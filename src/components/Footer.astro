<footer class="footer">
  <div class="container">
    <!-- Status indicator -->
    <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:2rem; font-size:0.875rem; color:var(--text-muted);">
      <div class="status-dot"></div>
      Systèmes opérationnels · 99.9% uptime
    </div>

    <div class="footer-grid">
      <!-- Brand column -->
      <div>
        <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:1rem;">
          <span style="font-size:1.25rem; font-weight:900; background:linear-gradient(135deg,#00e5ff,#7c3aed,#0066ff); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;">NEXUS AI</span>
        </div>
        <p style="color:var(--text-muted); font-size:0.9375rem; line-height:1.6; max-width:260px;">L'intelligence artificielle au service de votre croissance. Automation, SEO IA, Chatbots & Analytics.</p>
        <div style="margin-top:1.25rem; display:flex; flex-direction:column; gap:0.5rem; font-size:0.875rem; color:var(--text-muted);">
          <span>📞 01 84 00 00 00</span>
          <span>✉️ hello@nexus-ai.fr</span>
          <span>📍 Paris 8ème · Montpellier</span>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h4 style="color:var(--text); margin-bottom:1rem; font-size:0.9375rem;">Services</h4>
        <nav class="footer-links">
          <a href="/services/automation-ia">Automation IA</a>
          <a href="/services/seo-ia">SEO Intelligence</a>
          <a href="/services/developpement-web">Développement Web</a>
          <a href="/services/chatbot">Chatbot IA</a>
          <a href="/services/analytics">Analytics</a>
          <a href="/services/formation-ia">Formation IA</a>
        </nav>
      </div>

      <!-- Solutions -->
      <div>
        <h4 style="color:var(--text); margin-bottom:1rem; font-size:0.9375rem;">Solutions</h4>
        <nav class="footer-links">
          <a href="/solutions/pme">PME</a>
          <a href="/solutions/e-commerce">E-commerce</a>
          <a href="/solutions/agences">Agences</a>
          <a href="/cas-clients">Cas clients</a>
          <a href="/pricing">Tarifs</a>
          <a href="/demo">Démo gratuite</a>
        </nav>
      </div>

      <!-- Villes -->
      <div>
        <h4 style="color:var(--text); margin-bottom:1rem; font-size:0.9375rem;">Nos villes</h4>
        <nav class="footer-links">
          <a href="/villes/paris">Paris</a>
          <a href="/villes/montpellier">Montpellier</a>
          <a href="/villes/lyon">Lyon</a>
          <a href="/villes/bordeaux">Bordeaux</a>
          <a href="/villes/toulouse">Toulouse</a>
        </nav>
      </div>

      <!-- Légal -->
      <div>
        <h4 style="color:var(--text); margin-bottom:1rem; font-size:0.9375rem;">Entreprise</h4>
        <nav class="footer-links">
          <a href="/a-propos">À propos</a>
          <a href="/equipe">Notre équipe</a>
          <a href="/blog">Blog IA</a>
          <a href="/mentions-legales">Mentions légales</a>
          <a href="/cgv">CGV</a>
        </nav>
      </div>
    </div>

    <!-- Bottom bar -->
    <div style="border-top:1px solid var(--border); padding-top:1.5rem; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem;">
      <p style="color:var(--text-muted); font-size:0.8125rem;">© 2025 Nexus AI — Tous droits réservés</p>
      <p style="color:var(--text-muted); font-size:0.8125rem; opacity:0.6;">Template <strong style="color:var(--cyan);">D2 TECH PREMIUM</strong> · WebTrafic</p>
