---
---
<section class="hero dot-grid">
  <!-- Aurora background -->
  <div class="aurora-bg">
    <div class="aurora-blob"></div>
    <div class="aurora-blob"></div>
    <div class="aurora-blob"></div>
    <div class="aurora-blob"></div>
  </div>

  <div class="container hero-content">
    <div style="max-width:800px;">
      <!-- Top badge -->
      <div class="badge badge-violet mb-4 fade-in">
        <span style="width:6px;height:6px;border-radius:50%;background:#a78bfa;animation:pulse-badge 2s ease-in-out infinite;"></span>
        IA · Automation · Performance
      </div>

      <!-- H1 -->
      <h1 class="fade-in" style="margin-bottom:1.5rem;">
        L'IA qui<br/>
        <span style="color:var(--white);">multiplie</span><br/>
        <span class="gradient-text" id="rotating-word">vos leads</span>
      </h1>

      <!-- Subtitle with terminal cursor -->
      <p class="terminal-cursor fade-in" style="font-size:1.25rem; color:rgba(226,232,240,0.7); max-width:560px; margin-bottom:2.5rem;">
        Automatisez, optimisez et scalez votre business avec notre plateforme IA
      </p>

      <!-- CTAs -->
      <div class="flex gap-2 fade-in" style="flex-wrap:wrap;">
        <a href="/contact" class="btn btn-primary">🚀 Lancer mon projet</a>
        <a href="/demo" class="btn btn-outline">▶ Démo gratuite</a>
      </div>

      <!-- Client logos -->
      <div style="margin-top:4rem;" class="fade-in">
        <p style="font-size:0.8125rem; color:var(--text-muted); letter-spacing:0.1em; text-transform:uppercase; margin-bottom:1.25rem;">Ils nous font confiance</p>
        <div style="display:flex; flex-wrap:wrap; gap:2rem; align-items:center;">
          {['ACME Corp','TechVision','DataFlow','NovaSys','PulseAI','ByteForge','CloudNex','Strateos'].map(logo => (
            <div style="color:var(--text-muted); font-weight:700; font-size:0.9375rem; letter-spacing:-0.02em; opacity:0.35; transition:opacity 0.3s;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='0.35'">{logo}</div>
          ))}
        </div>
      </div>
    </div>

    <!-- Floating dashboard card -->
    <div class="tilt-card card" style="position:absolute; right:2rem; top:50%; transform:translateY(-50%); width:320px; background:rgba(10,15,30,0.9); backdrop-filter:blur(20px);" id="dashboard-card">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
        <span style="font-size:0.875rem; color:var(--text-muted);">ROI Dashboard</span>
        <span class="badge badge-cyan" style="font-size:0.75rem; padding:0.25rem 0.625rem;">LIVE</span>
      </div>

      <!-- Big stat -->
      <div style="margin-bottom:1.5rem;">
        <div class="stat-number">+340%</div>
        <div style="font-size:0.875rem; color:var(--text-muted);">Retour sur investissement moyen</div>
      </div>

      <!-- SVG graph -->
      <svg viewBox="0 0 300 80" style="width:100%; height:80px;">
        <defs>
          <linearGradient id="graph-grad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#00e5ff" stop-opacity="0.3"/>
            <stop offset="100%" stop-color="#00e5ff" stop-opacity="0"/>
          </linearGradient>
        </defs>
        <path d="M0,70 L25,65 L50,58 L75,50 L100,40 L125,35 L150,25 L175,18 L200,12 L225,8 L250,5 L275,3 L300,1" stroke="#00e5ff" stroke-width="2.5" fill="none" class="graph-line"/>
        <path d="M0,70 L25,65 L50,58 L75,50 L100,40 L125,35 L150,25 L175,18 L200,12 L225,8 L250,5 L275,3 L300,1 L300,80 L0,80Z" fill="url(#graph-grad)"/>
      </svg>

      <!-- Mini stats -->
      <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:0.75rem; margin-top:1rem; padding-top:1rem; border-top:1px solid var(--border);">
        <div style="text-align:center;">
          <div style="font-weight:800; color:var(--cyan); font-size:1.125rem;">150+</div>
          <div style="font-size:0.75rem; color:var(--text-muted);">Clients</div>
        </div>
        <div style="text-align:center;">
          <div style="font-weight:800; color:#a78bfa; font-size:1.125rem;">99.9%</div>
          <div style="font-size:0.75rem; color:var(--text-muted);">Uptime</div>
        </div>
        <div style="text-align:center;">
          <div style="font-weight:800; color:#60a5fa; font-size:1.125rem;">24/7</div>
          <div style="font-size:0.75rem; color:var(--text-muted);">Support</div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Rotating words typewriter
  const words = ['vos leads', 'votre ROI', 'votre visibilité', 'vos conversions', 'votre croissance'];
  let i = 0;
  const el = document.getElementById('rotating-word');
  if (el) {
    setInterval(() => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(10px)';
      setTimeout(() => {
        i = (i + 1) % words.length;
        el.textContent = words[i];
        el.style.opacity = '1';
        el.style.transform = 'translateY(0)';
      }, 300);
    }, 2800);
    el.style.transition = 'opacity 0.3s, transform 0.3s';
  }

  // Dashboard card position responsive
  function positionCard() {
    const card = document.getElementById('dashboard-card');
    if (card) {
      if (window.innerWidth < 1200) {
        card.style.display = 'none';
      } else {
        card.style.display = 'block';
      }
    }
  }
  positionCard();
  window.addEventListener('resize', positionCard);
</script>
