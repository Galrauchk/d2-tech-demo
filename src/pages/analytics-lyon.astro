---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Analytics IA Lyon — Tableaux de Bord Prédictifs AURA | Nexus AI"
  description="Solutions Analytics IA à Lyon et en Auvergne-Rhône-Alpes. Dashboards temps réel, forecasting IA. Décidez mieux pour votre business lyonnais. Démo gratuite."
>
  <Header slot="header" />
  <div class="page-hero dot-grid">
    <div class="aurora-bg"><div class="aurora-blob"></div><div class="aurora-blob"></div></div>
    <div class="container page-hero-content">
      <nav class="breadcrumb">
        <a href="/">Accueil</a><span class="breadcrumb-sep">/</span>
        <a href="/villes/lyon">Lyon</a><span class="breadcrumb-sep">/</span>
        <span style="color:var(--cyan);">Analytics IA</span>
      </nav>
      <div class="badge badge-violet mb-3">📍 Lyon · Analytics IA</div>
      <h1 style="max-width:700px; margin-bottom:1.5rem;">Analytics IA Lyon<br/><span class="gradient-text">Pilotez avec précision</span></h1>
      <p style="color:var(--text-muted); font-size:1.25rem; max-width:560px; margin-bottom:2.5rem;">Déployez un dashboard Analytics IA pour votre entreprise lyonnaise. Données temps réel, prédictions IA, alertes automatiques. Opérationnel en 1 semaine.</p>
      <div class="flex gap-2" style="flex-wrap:wrap;">
        <a href="/contact" class="btn btn-primary">Démo Analytics Lyon →</a>
        <a href="/services/analytics" class="btn btn-outline">En savoir plus</a>
      </div>
    </div>
  </div>
  <section class="section" style="background:var(--surface-dark);">
    <div class="container">
      <div class="grid-3 fade-in">
        {[
          { n: 'Temps réel', l: 'Dashboard live', d: 'Données actualisées' },
          { n: '99.5%', l: 'Précision IA', d: 'Modèles prédictifs' },
          { n: '1 sem.', l: 'Déploiement', d: "Du brief à l'opérationnel" }
        ].map(s => (
          <div class="card text-center tilt-card">
            <div class="stat-number" style="font-size:2rem;">{s.n}</div>
            <div style="font-weight:700; margin:0.5rem 0 0.25rem;">{s.l}</div>
            <div style="color:var(--text-muted); font-size:0.875rem;">{s.d}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section class="section" style="background:linear-gradient(135deg,rgba(0,229,255,0.05),rgba(124,58,237,0.08)); border-top:1px solid var(--border);">
    <div class="container text-center fade-in">
      <h2 style="margin-bottom:1rem;">Analytics IA Lyon<br/><span class="gradient-text">démo live gratuite</span></h2>
      <a href="/contact" class="btn btn-primary">Réserver ma démo →</a>
    </div>
  </section>
  <Footer slot="footer" />
</Layout>
