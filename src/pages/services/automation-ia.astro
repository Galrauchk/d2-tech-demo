---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Automation IA",
  "provider": { "@type": "Organization", "name": "Nexus AI" },
  "description": "Automatisation intelligente de vos processus métier grâce à l'IA",
  "areaServed": "FR"
};
const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://d2-tech-demo.netlify.app" },
    { "@type": "ListItem", "position": 2, "name": "Services" },
    { "@type": "ListItem", "position": 3, "name": "Automation IA" }
  ]
};

const useCases = [
  { t: 'Traitement emails', d: "Tri, catégorisation et réponses automatiques aux emails clients avec l'IA. Réduction du temps de traitement de 80%." },
  { t: 'Génération de rapports', d: 'Rapports business générés automatiquement chaque semaine sans intervention humaine. Données consolidées en temps réel.' },
  { t: 'Pipeline commercial', d: "Qualification leads, suivi CRM et relances automatiques pilotés par l'IA. Taux de conversion +45%." },
  { t: 'Support client', d: "Tickets triés, routés et partiellement répondus par notre IA avant l'agent humain. NPS +38 points." },
  { t: 'Facturation automatique', d: 'Génération et envoi automatique des factures, relances impayés intégrées. Zéro saisie manuelle.' },
  { t: 'Data entry IA', d: "Extraction et saisie automatique depuis PDFs, emails, formulaires grâce à l'OCR IA. Précision 99.2%." }
];

const steps = [
  { n: '01', t: 'Audit de vos processus', d: "Analyse complète de vos workflows existants et identification des processus à fort potentiel d'automatisation. Rapport ROI estimatif inclus." },
  { n: '02', t: 'Design des workflows IA', d: "Conception des automatisations adaptées à votre métier avec notre équipe de consultants IA certifiés." },
  { n: '03', t: 'Développement & intégration', d: "Développement des automatisations et intégration avec vos outils existants (CRM, ERP, Slack, email, etc.)." },
  { n: '04', t: 'Formation & accompagnement', d: "Formation de vos équipes et accompagnement continu pour maximiser l'adoption et le ROI." }
];
---

<Layout
  title="Automation IA — Automatisez vos processus avec l'IA | Nexus AI"
  description="Automatisez vos processus métier avec l'IA. Gagnez 20h/semaine, réduisez vos erreurs de 95%. Solutions d'automation IA clé en main pour PME et ETI. Paris, Montpellier."
  schema={[schema, breadcrumb]}
>
  <Header slot="header" />

  <div class="page-hero dot-grid">
    <div class="aurora-bg"><div class="aurora-blob"></div><div class="aurora-blob"></div></div>
    <div class="container page-hero-content">
      <nav class="breadcrumb">
        <a href="/">Accueil</a>
        <span class="breadcrumb-sep">/</span>
        <span>Services</span>
        <span class="breadcrumb-sep">/</span>
        <span style="color:var(--cyan);">Automation IA</span>
      </nav>
      <div class="badge badge-cyan mb-3">Service Premium</div>
      <h1 style="max-width:700px; margin-bottom:1.5rem;">
        Automation IA<br/>
        <span class="gradient-text">Libérez votre potentiel</span>
      </h1>
      <p style="color:var(--text-muted); font-size:1.25rem; max-width:560px; margin-bottom:2.5rem;">
        Automatisez vos tâches répétitives avec des workflows IA intelligents. Gagnez 20h/semaine et concentrez-vous sur ce qui compte vraiment pour votre croissance.
      </p>
      <div class="flex gap-2" style="flex-wrap:wrap;">
        <a href="/contact" class="btn btn-primary">Démarrer l'automation →</a>
        <a href="/demo" class="btn btn-outline">Voir une démo</a>
      </div>
    </div>
  </div>

  <!-- Stats -->
  <section class="section" style="background:var(--surface-dark);">
    <div class="container">
      <div class="grid-3">
        {[
          { n: '20h', l: 'Gagnées/semaine', d: 'En moyenne par équipe de 5 personnes' },
          { n: '95%', l: "Moins d'erreurs", d: "Grâce à l'automatisation des processus" },
          { n: 'x4', l: 'ROI moyen', d: 'Constaté sur 12 mois chez nos clients' }
        ].map(s => (
          <div class="card text-center tilt-card fade-in">
            <div class="stat-number">{s.n}</div>
            <div style="font-weight:700; margin:0.5rem 0 0.25rem;">{s.l}</div>
            <div style="color:var(--text-muted); font-size:0.875rem;">{s.d}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="section" style="background:var(--bg-dark);">
    <div class="container">
      <div class="text-center mb-6 fade-in">
        <div class="badge badge-violet mb-3">Cas d'usage</div>
        <h2>Ce que nous <span class="gradient-text">automatisons</span></h2>
        <p style="color:var(--text-muted); max-width:500px; margin:1rem auto 0;">Des processus métier concrets, automatisés de bout en bout pour un ROI immédiat.</p>
      </div>
      <div class="grid-3">
        {useCases.map(item => (
          <div class="card tilt-card fade-in">
            <div class="service-icon icon-cyan" style="font-size:1.5rem; width:48px; height:48px;">⚡</div>
            <h3 style="font-size:1.125rem; margin-bottom:0.5rem;">{item.t}</h3>
            <p style="color:var(--text-muted); font-size:0.9375rem;">{item.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section" style="background:var(--surface-dark);">
    <div class="container" style="max-width:800px;">
      <div class="text-center mb-6 fade-in">
        <div class="badge badge-cyan mb-3">Méthodologie</div>
        <h2>Notre <span class="gradient-text">processus</span> en 4 étapes</h2>
      </div>
      {steps.map((step, i) => (
        <div class="fade-in" style={`display:flex; gap:1.5rem; margin-bottom:2rem; align-items:flex-start;`}>
          <div class="step-number">{step.n}</div>
          <div>
            <h3 style="margin-bottom:0.5rem;">{step.t}</h3>
            <p style="color:var(--text-muted);">{step.d}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Integrations -->
  <section class="section" style="background:var(--bg-dark);">
    <div class="container">
      <div class="text-center mb-6 fade-in">
        <h2>Intégrations <span class="gradient-text">natives</span></h2>
        <p style="color:var(--text-muted); max-width:500px; margin:1rem auto 0;">Nexus AI se connecte à vos outils existants en quelques clics, sans développement complexe.</p>
      </div>
      <div style="display:flex; flex-wrap:wrap; gap:1rem; justify-content:center;" class="fade-in">
        {['Salesforce', 'HubSpot', 'Pipedrive', 'Slack', 'Notion', 'Airtable', 'Google Workspace', 'Microsoft 365', 'Zapier', 'Make', 'Stripe', 'Shopify'].map(tool => (
          <div class="tag">{tool}</div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="background:linear-gradient(135deg,rgba(0,229,255,0.05),rgba(124,58,237,0.08)); border-top:1px solid var(--border);">
    <div class="container text-center fade-in">
      <div class="badge badge-violet mb-4">Prêt à automatiser ?</div>
      <h2 style="margin-bottom:1rem;">Démarrez votre audit<br/><span class="gradient-text">gratuitement</span></h2>
      <p style="color:var(--text-muted); max-width:480px; margin:0 auto 2rem;">Nos experts analysent vos processus et vous proposent un plan d'automation personnalisé.</p>
      <a href="/contact" class="btn btn-primary">Démarrer gratuitement →</a>
      <p style="margin-top:1rem; font-size:0.875rem; color:var(--text-muted);">✓ Audit offert · ✓ Résultats en 30 jours · ✓ Sans engagement</p>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
