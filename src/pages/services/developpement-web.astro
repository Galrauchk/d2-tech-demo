---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Développement Web IA",
  "provider": { "@type": "Organization", "name": "Nexus AI" },
  "description": "Développement de sites et applications web ultra-performants avec IA intégrée",
  "areaServed": "FR"
};
const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://d2-tech-demo.netlify.app" },
    { "@type": "ListItem", "position": 2, "name": "Services" },
    { "@type": "ListItem", "position": 3, "name": "Développement Web" }
  ]
};

const techStack = ['Next.js', 'Astro', 'React', 'TypeScript', 'Node.js', 'Python', 'PostgreSQL', 'Supabase', 'Vercel', 'Tailwind CSS', 'Stripe', 'OpenAI API'];
---

<Layout
  title="Développement Web IA — Sites & Apps Ultra-Performants | Nexus AI"
  description="Développement web avec IA intégrée. Sites Astro, Next.js, React. Performance 98+/100 Lighthouse. Déploiement continu. Paris, Montpellier. Devis gratuit."
  schema={[schema, breadcrumb]}
>
  <Header slot="header" />

  <div class="page-hero dot-grid">
    <div class="aurora-bg"><div class="aurora-blob"></div><div class="aurora-blob"></div></div>
    <div class="container page-hero-content">
      <nav class="breadcrumb">
        <a href="/">Accueil</a>
        <span class="breadcrumb-sep">/</span>
        <span>Services</span>
        <span class="breadcrumb-sep">/</span>
        <span style="color:var(--cyan);">Développement Web</span>
      </nav>
      <div class="badge badge-blue mb-3" style="background:rgba(0,102,255,0.1); color:#60a5fa; border:1px solid rgba(0,102,255,0.2);">Développement Premium</div>
      <h1 style="max-width:700px; margin-bottom:1.5rem;">
        Sites & Apps Web<br/>
        <span class="gradient-text">IA-first, ultra-performants</span>
      </h1>
      <p style="color:var(--text-muted); font-size:1.25rem; max-width:560px; margin-bottom:2.5rem;">
        Nous développons des sites web et applications qui intègrent l'IA nativement. Performance 98/100 Lighthouse, SEO parfait, expérience utilisateur exceptionnelle.
      </p>
      <div class="flex gap-2" style="flex-wrap:wrap;">
        <a href="/contact" class="btn btn-primary">Démarrer mon projet →</a>
        <a href="/demo" class="btn btn-outline">Voir nos réalisations</a>
      </div>
    </div>
  </div>

  <!-- Stats -->
  <section class="section" style="background:var(--surface-dark);">
    <div class="container">
      <div class="grid-4 fade-in">
        {[
          { n: '98+', l: 'Score Lighthouse', d: 'Performance garantie' },
          { n: '< 1s', l: 'Time to First Byte', d: 'Chargement ultra-rapide' },
          { n: '100%', l: 'Responsive', d: 'Tous appareils' },
          { n: 'A+', l: 'Sécurité SSL', d: 'Headers optimisés' }
        ].map(s => (
          <div class="card text-center tilt-card fade-in">
            <div class="stat-number">{s.n}</div>
            <div style="font-weight:700; margin:0.5rem 0 0.25rem;">{s.l}</div>
            <div style="color:var(--text-muted); font-size:0.8125rem;">{s.d}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section" style="background:var(--bg-dark);">
    <div class="container">
      <div class="text-center mb-6 fade-in">
        <div class="badge badge-cyan mb-3">Expertises</div>
        <h2>Ce que nous <span class="gradient-text">développons</span></h2>
      </div>
      <div class="grid-3">
        {[
          { icon: '🌐', t: 'Sites vitrine & corporate', d: "Sites institutionnels ultra-rapides avec Astro ou Next.js. Design sur mesure, CMS headless, SEO parfait dès le départ." },
          { icon: '🛒', t: 'E-commerce IA', d: "Boutiques en ligne avec recommandations produits IA, recherche intelligente, panier optimisé. Conversion +35%." },
          { icon: '📱', t: 'Applications web (SaaS)', d: "Plateformes SaaS complètes avec authentification, paiement Stripe, tableau de bord, API REST. Stack moderne et scalable." },
          { icon: '🤖', t: 'Intégration IA/LLM', d: "Intégration d'OpenAI, Anthropic, Mistral dans vos apps existantes. Chatbots, génération de contenu, analyse de données." },
          { icon: '⚡', t: 'Optimisation performance', d: "Audit et optimisation de vos sites existants. Core Web Vitals, lazy loading, CDN, cache. Score 90+ garanti." },
          { icon: '🔄', t: 'Migration & refonte', d: "Migration de votre site legacy vers une stack moderne. Zéro perte de SEO, processus maîtrisé et sécurisé." }
        ].map(f => (
          <div class="card tilt-card fade-in">
            <div style="font-size:2rem; margin-bottom:1rem;">{f.icon}</div>
            <h3 style="margin-bottom:0.75rem;">{f.t}</h3>
            <p style="color:var(--text-muted); font-size:0.9375rem;">{f.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="section" style="background:var(--surface-dark);">
    <div class="container text-center">
      <div class="fade-in mb-6">
        <div class="badge badge-violet mb-3">Stack technique</div>
        <h2>Technologies <span class="gradient-text">de pointe</span></h2>
        <p style="color:var(--text-muted); max-width:500px; margin:1rem auto 0;">Nous utilisons les meilleures technologies modernes pour garantir performance, scalabilité et maintenabilité.</p>
      </div>
      <div style="display:flex; flex-wrap:wrap; gap:1rem; justify-content:center;" class="fade-in">
        {techStack.map(t => (
          <div class="tag">{t}</div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section" style="background:var(--bg-dark);">
    <div class="container" style="max-width:800px;">
      <div class="text-center mb-6 fade-in">
        <h2>Processus <span class="gradient-text">de développement</span></h2>
      </div>
      {[
        { n: '01', t: 'Brief & cahier des charges', d: "Réunion de cadrage pour définir vos objectifs, contraintes techniques et fonctionnelles. Livraison d'un cahier des charges complet." },
        { n: '02', t: 'Design UI/UX', d: "Maquettes Figma interactives. Validation du design avant tout développement. Expérience utilisateur optimisée par les données." },
        { n: '03', t: 'Développement itératif', d: "Sprints de 2 semaines avec démos régulières. Code reviewé, testé automatiquement. Intégration continue dès le premier jour." },
        { n: '04', t: 'Tests & mise en production', d: "Tests fonctionnels, cross-browser, performance et sécurité. Déploiement progressif avec monitoring temps réel." }
      ].map((step, i) => (
        <div class="fade-in" style="display:flex; gap:1.5rem; margin-bottom:2rem; align-items:flex-start;">
          <div class="step-number">{step.n}</div>
          <div>
            <h3 style="margin-bottom:0.5rem;">{step.t}</h3>
            <p style="color:var(--text-muted);">{step.d}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="background:linear-gradient(135deg,rgba(0,229,255,0.05),rgba(124,58,237,0.08)); border-top:1px solid var(--border);">
    <div class="container text-center fade-in">
      <h2 style="margin-bottom:1rem;">Votre projet mérite<br/><span class="gradient-text">le meilleur</span></h2>
      <p style="color:var(--text-muted); max-width:480px; margin:0 auto 2rem;">Obtenez un devis personnalisé en 24h. Nos développeurs experts analysent votre besoin et vous proposent la solution optimale.</p>
      <a href="/contact" class="btn btn-primary">Obtenir un devis gratuit →</a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
