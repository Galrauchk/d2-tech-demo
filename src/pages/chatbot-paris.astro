---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Chatbot IA Paris",
  "provider": { "@type": "Organization", "name": "Nexus AI" },
  "areaServed": { "@type": "City", "name": "Paris" }
};
---

<Layout
  title="Chatbot IA Paris — Service Client 24/7 pour Entreprises Parisiennes | Nexus AI"
  description="Déployez un chatbot IA à Paris. Service client 24/7, 80% de résolution automatique, NPS +45 pts. Configuration en 2 semaines. Paris et Île-de-France."
  schema={schema}
>
  <Header slot="header" />

  <div class="page-hero dot-grid">
    <div class="aurora-bg"><div class="aurora-blob"></div><div class="aurora-blob"></div></div>
    <div class="container page-hero-content">
      <nav class="breadcrumb">
        <a href="/">Accueil</a>
        <span class="breadcrumb-sep">/</span>
        <a href="/villes/paris">Paris</a>
        <span class="breadcrumb-sep">/</span>
        <span style="color:var(--cyan);">Chatbot IA</span>
      </nav>
      <div class="badge badge-cyan mb-3">📍 Paris · Chatbot IA</div>
      <h1 style="max-width:700px; margin-bottom:1.5rem;">
        Chatbot IA Paris<br/>
        <span class="gradient-text">Service client sans limites</span>
      </h1>
      <p style="color:var(--text-muted); font-size:1.25rem; max-width:560px; margin-bottom:2.5rem;">
        Les Parisiens sont exigeants. Ils veulent des réponses instantanées, disponibles 24/7. Notre chatbot IA s'adapte à vos clients parisiens et à votre secteur d'activité.
      </p>
      <div class="flex gap-2" style="flex-wrap:wrap;">
        <a href="/contact" class="btn btn-primary">Déployer mon chatbot Paris →</a>
        <a href="/services/chatbot" class="btn btn-outline">Voir la démo</a>
      </div>
    </div>
  </div>

  <section class="section" style="background:var(--surface-dark);">
    <div class="container">
      <div class="grid-3 fade-in">
        {[
          { n: '80%', l: 'Résolution auto.', d: 'Sans intervention humaine' },
          { n: '< 30s', l: 'Temps de réponse', d: 'Vs 4h en moyenne sans IA' },
          { n: '+45', l: 'Points NPS', d: 'Gain satisfaction client' }
        ].map(s => (
          <div class="card text-center tilt-card">
            <div class="stat-number">{s.n}</div>
            <div style="font-weight:700; margin:0.5rem 0 0.25rem;">{s.l}</div>
            <div style="color:var(--text-muted); font-size:0.875rem;">{s.d}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--bg-dark);">
    <div class="container">
      <div class="grid-2 fade-in">
        <div>
          <h2 style="margin-bottom:1.5rem;">Chatbot IA <span class="gradient-text">adapté à Paris</span></h2>
          <p style="color:var(--text-muted); margin-bottom:1rem;">Le marché parisien regroupe tous les secteurs : luxe, finance, tourisme, tech, retail... Chaque secteur a ses codes et ses attentes. Notre chatbot s'y adapte parfaitement.</p>
          <p style="color:var(--text-muted); margin-bottom:1.5rem;">Multilingue (français, anglais, espagnol, mandarin), notre solution est idéale pour les entreprises parisiennes qui accueillent une clientèle internationale.</p>
          <a href="/contact" class="btn btn-primary" style="margin-top:0.5rem;">Démo personnalisée →</a>
        </div>
        <div class="card tilt-card">
          <h3 style="margin-bottom:1rem; color:var(--cyan);">Cas d'usage Paris</h3>
          {[
            { s: 'Hôtellerie & Tourisme', d: "Réservations, informations, conciergerie IA" },
            { s: 'Finance & Banque', d: "FAQ produits, orientation, simulation" },
            { s: 'Mode & Luxe', d: "Service client premium, styling IA" },
            { s: 'Immobilier', d: "Visites virtuelles, qualification leads" },
            { s: 'Restauration', d: "Réservations, menu IA, allerg." }
          ].map(item => (
            <div style="padding:0.625rem 0; border-bottom:1px solid var(--border);">
              <div style="font-weight:600; font-size:0.875rem;">{item.s}</div>
              <div style="color:var(--text-muted); font-size:0.8125rem;">{item.d}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="background:linear-gradient(135deg,rgba(0,229,255,0.05),rgba(124,58,237,0.08)); border-top:1px solid var(--border);">
    <div class="container text-center fade-in">
      <h2 style="margin-bottom:1rem;">Votre chatbot parisien<br/><span class="gradient-text">prêt en 2 semaines</span></h2>
      <a href="/contact" class="btn btn-primary">Démarrer maintenant →</a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
