---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Qu'est-ce que Nexus AI ?", "acceptedAnswer": { "@type": "Answer", "text": "Nexus AI est une agence française spécialisée en intelligence artificielle et automatisation. Nous aidons les PME et ETI à multiplier leur ROI grâce à des solutions IA sur mesure : automation, SEO IA, chatbots, analytics prédictifs." } },
    { "@type": "Question", "name": "Combien coûte Nexus AI ?", "acceptedAnswer": { "@type": "Answer", "text": "Nos plans commencent à 299€/mois (Starter), puis 799€/mois (Growth) et sur devis pour l'Enterprise. Réduction de 20% avec l'abonnement annuel. Essai gratuit 30 jours disponible." } },
    { "@type": "Question", "name": "Faut-il des compétences techniques ?", "acceptedAnswer": { "@type": "Answer", "text": "Non. Nos solutions sont 100% clé en main. Nous gérons l'intégration, la configuration et la maintenance. Votre équipe utilise une interface intuitive sans code." } }
  ]
};

const faqs = [
  {
    cat: "Général",
    questions: [
      { q: "Qu'est-ce que Nexus AI ?", a: "Nexus AI est une agence française spécialisée en intelligence artificielle et automatisation, fondée à Montpellier en 2020. Nous aidons les PME et ETI à multiplier leur ROI grâce à des solutions IA sur mesure : automation de processus, SEO IA, chatbots intelligents et analytics prédictifs." },
      { q: "Êtes-vous une agence ou un éditeur de logiciel ?", a: "Les deux. Nous développons notre propre plateforme IA (propriétaire) ET nous accompagnons nos clients comme une agence : stratégie, déploiement, formation, optimisation continue. Le meilleur des deux mondes." },
      { q: "Où êtes-vous situés ?", a: "Notre siège est à Montpellier (34000). Nous avons des bureaux à Paris (8ème) et intervenons dans toute la France : Lyon, Bordeaux, Toulouse et au-delà. Intervention en présentiel ou à distance selon votre préférence." }
    ]
  },
  {
    cat: "Tarifs & Contrats",
    questions: [
      { q: "Quels sont vos tarifs ?", a: "Starter : 299€/mois, Growth : 799€/mois, Enterprise : sur devis. Réduction de 20% avec l'abonnement annuel. Essai gratuit 30 jours sans engagement sur tous les plans." },
      { q: "Y a-t-il un engagement minimum ?", a: "Non. Les plans mensuels sont sans engagement minimum. Annulez quand vous voulez. Le plan annuel est payé en une fois avec une remise de 20%, mais une résiliation anticipée donne droit à un remboursement au prorata." },
      { q: "Y a-t-il des frais d'installation ?", a: "Non. L'onboarding est entièrement gratuit et inclus dans tous nos plans. Nos équipes vous accompagnent pour la configuration initiale, les intégrations et la formation." }
    ]
  },
  {
    cat: "Technique",
    questions: [
      { q: "Faut-il des compétences techniques ?", a: "Non. Nos solutions sont 100% clé en main. Nous gérons l'intégration, la configuration et la maintenance. Votre équipe utilise une interface intuitive sans aucune ligne de code." },
      { q: "Avec quels outils vous intégrez-vous ?", a: "Nexus AI s'intègre nativement avec 50+ outils : Salesforce, HubSpot, Pipedrive, Slack, Google Workspace, Microsoft 365, Shopify, WooCommerce, Stripe, Zapier, Make, et bien d'autres. API REST disponible pour les intégrations custom." },
      { q: "Vos solutions sont-elles RGPD conformes ?", a: "Oui, à 100%. Toutes nos solutions sont hébergées sur des serveurs en France (OVH et Scaleway). Conformes RGPD et ISO 27001. Vos données ne quittent jamais le territoire européen. DPA (Data Processing Agreement) signable sur demande." }
    ]
  },
  {
    cat: "Résultats",
    questions: [
      { q: "Combien de temps pour voir des résultats ?", a: "Premiers résultats visibles dès 30 jours pour l'automation. 3 à 6 mois pour le SEO IA (délai naturel du référencement). Le chatbot est opérationnel en 2 semaines. Le ROI positif est généralement atteint entre 2 et 4 mois selon les solutions déployées." },
      { q: "Quel est le ROI moyen de vos clients ?", a: "Le ROI moyen constaté sur 12 mois est de +340%. Nos clients PME économisent en moyenne 20h/semaine grâce à l'automation et observent +180% de trafic SEO organique en 6 mois. Les résultats varient selon le secteur et l'engagement." },
      { q: "Garantissez-vous des résultats ?", a: "Nous garantissons notre implication et nos méthodes, éprouvées sur 150+ clients. Si vous ne constatez aucune amélioration mesurable dans les 30 premiers jours, nous vous remboursons intégralement — sans condition." }
    ]
  }
];
---

<Layout
  title="FAQ Nexus AI — Toutes vos Questions sur l'IA | Nexus AI"
  description="Réponses à toutes vos questions sur Nexus AI : tarifs, fonctionnalités, conformité RGPD, délais, intégrations. Tout ce que vous voulez savoir avant de vous lancer."
  schema={faqSchema}
>
  <Header slot="header" />

  <div class="page-hero dot-grid">
    <div class="aurora-bg"><div class="aurora-blob"></div><div class="aurora-blob"></div></div>
    <div class="container page-hero-content text-center">
      <nav class="breadcrumb" style="justify-content:center;">
        <a href="/">Accueil</a>
        <span class="breadcrumb-sep">/</span>
        <span style="color:var(--cyan);">FAQ</span>
      </nav>
      <div class="badge badge-cyan mb-4">FAQ</div>
      <h1 style="margin-bottom:1rem;">Vos questions, <span class="gradient-text">nos réponses</span></h1>
      <p style="color:var(--text-muted); font-size:1.25rem; max-width:540px; margin:0 auto;">Tout ce que vous devez savoir sur Nexus AI, nos solutions, tarifs et garanties.</p>
    </div>
  </div>

  <section class="section" style="background:var(--surface-dark);">
    <div class="container" style="max-width:900px;">
      {faqs.map(section => (
        <div style="margin-bottom:3rem;" class="fade-in">
          <div class="badge badge-violet mb-4">{section.cat}</div>
          {section.questions.map(item => (
            <div class="faq-item">
              <button class="faq-question">
                {item.q}
                <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </button>
              <div class="faq-answer">{item.a}</div>
            </div>
          ))}
        </div>
      ))}
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="section" style="background:linear-gradient(135deg,rgba(0,229,255,0.05),rgba(124,58,237,0.08)); border-top:1px solid var(--border);">
    <div class="container text-center fade-in">
      <h2 style="margin-bottom:1rem;">Vous n'avez pas trouvé<br/><span class="gradient-text">votre réponse ?</span></h2>
      <p style="color:var(--text-muted); max-width:480px; margin:0 auto 2rem;">Notre équipe répond à toutes vos questions en moins de 2h en jours ouvrés.</p>
      <div class="flex-center gap-2" style="flex-wrap:wrap;">
        <a href="/contact" class="btn btn-primary">Nous contacter →</a>
        <a href="tel:+33184000000" class="btn btn-outline">01 84 00 00 00</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
