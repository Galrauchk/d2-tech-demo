---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Chatbot IA Toulouse — Service Client 24/7 pour Entreprises Toulousaines | Nexus AI"
  description="Déployez un chatbot IA à Toulouse. 80% résolution automatique. Adapté aux secteurs aéronautique, services, tech de Toulouse. Configuration en 2 semaines."
>
  <Header slot="header" />
  <div class="page-hero dot-grid">
    <div class="aurora-bg"><div class="aurora-blob"></div><div class="aurora-blob"></div></div>
    <div class="container page-hero-content">
      <nav class="breadcrumb">
        <a href="/">Accueil</a><span class="breadcrumb-sep">/</span>
        <a href="/villes/toulouse">Toulouse</a><span class="breadcrumb-sep">/</span>
        <span style="color:var(--cyan);">Chatbot IA</span>
      </nav>
      <div class="badge badge-cyan mb-3">📍 Toulouse · Chatbot IA</div>
      <h1 style="max-width:700px; margin-bottom:1.5rem;">Chatbot IA Toulouse<br/><span class="gradient-text">Service client sans limites</span></h1>
      <p style="color:var(--text-muted); font-size:1.25rem; max-width:560px; margin-bottom:2.5rem;">Automatisez votre service client toulousain. Notre chatbot IA s'adapte aux spécificités de votre secteur, de l'aéronautique aux services professionnels.</p>
      <div class="flex gap-2" style="flex-wrap:wrap;">
        <a href="/contact" class="btn btn-primary">Déployer mon chatbot →</a>
        <a href="/services/chatbot" class="btn btn-outline">Voir la démo</a>
      </div>
    </div>
  </div>
  <section class="section" style="background:var(--surface-dark);">
    <div class="container">
      <div class="grid-3 fade-in">
        {[
          { n: '80%', l: 'Résolution auto.', d: 'Sans agent humain' },
          { n: '24/7', l: 'Disponibilité', d: '365 jours par an' },
          { n: '2 sem.', l: 'Déploiement', d: 'Opérationnel rapidement' }
        ].map(s => (
          <div class="card text-center tilt-card">
            <div class="stat-number">{s.n}</div>
            <div style="font-weight:700; margin:0.5rem 0 0.25rem;">{s.l}</div>
            <div style="color:var(--text-muted); font-size:0.875rem;">{s.d}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section class="section" style="background:linear-gradient(135deg,rgba(0,229,255,0.05),rgba(124,58,237,0.08)); border-top:1px solid var(--border);">
    <div class="container text-center fade-in">
      <h2 style="margin-bottom:1rem;">Votre chatbot toulousain<br/><span class="gradient-text">prêt en 2 semaines</span></h2>
      <a href="/contact" class="btn btn-primary">Démarrer maintenant →</a>
    </div>
  </section>
  <Footer slot="footer" />
</Layout>
