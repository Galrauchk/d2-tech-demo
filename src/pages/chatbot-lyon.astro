---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Chatbot IA Lyon",
  "provider": { "@type": "Organization", "name": "Nexus AI" },
  "areaServed": { "@type": "City", "name": "Lyon" }
};
---

<Layout
  title="Chatbot IA Lyon — Service Client 24/7 pour Entreprises Lyonnaises | Nexus AI"
  description="Déployez un chatbot IA à Lyon. 80% résolution automatique, NPS +45 pts, coûts support -60%. Configuration en 2 semaines. Auvergne-Rhône-Alpes."
  schema={schema}
>
  <Header slot="header" />
  <div class="page-hero dot-grid">
    <div class="aurora-bg"><div class="aurora-blob"></div><div class="aurora-blob"></div></div>
    <div class="container page-hero-content">
      <nav class="breadcrumb">
        <a href="/">Accueil</a><span class="breadcrumb-sep">/</span>
        <a href="/villes/lyon">Lyon</a><span class="breadcrumb-sep">/</span>
        <span style="color:var(--cyan);">Chatbot IA</span>
      </nav>
      <div class="badge badge-cyan mb-3">📍 Lyon · Chatbot IA</div>
      <h1 style="max-width:700px; margin-bottom:1.5rem;">Chatbot IA Lyon<br/><span class="gradient-text">Service client 24/7</span></h1>
      <p style="color:var(--text-muted); font-size:1.25rem; max-width:560px; margin-bottom:2.5rem;">Automatisez votre service client lyonnais avec un chatbot IA intelligent. Adapté aux secteurs industriels, santé, services et retail de la région Auvergne-Rhône-Alpes.</p>
      <div class="flex gap-2" style="flex-wrap:wrap;">
        <a href="/contact" class="btn btn-primary">Déployer mon chatbot Lyon →</a>
        <a href="/services/chatbot" class="btn btn-outline">En savoir plus</a>
      </div>
    </div>
  </div>
  <section class="section" style="background:var(--surface-dark);">
    <div class="container">
      <div class="grid-3 fade-in">
        {[
          { n: '80%', l: 'Résolution auto.', d: 'Sans agent humain' },
          { n: '-60%', l: 'Coûts support', d: 'Économies réalisées' },
          { n: '2 sem.', l: 'Déploiement', d: 'Du brief au go-live' }
        ].map(s => (
          <div class="card text-center tilt-card">
            <div class="stat-number">{s.n}</div>
            <div style="font-weight:700; margin:0.5rem 0 0.25rem;">{s.l}</div>
            <div style="color:var(--text-muted); font-size:0.875rem;">{s.d}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section class="section" style="background:linear-gradient(135deg,rgba(0,229,255,0.05),rgba(124,58,237,0.08)); border-top:1px solid var(--border);">
    <div class="container text-center fade-in">
      <h2 style="margin-bottom:1rem;">Votre chatbot lyonnais<br/><span class="gradient-text">prêt en 2 semaines</span></h2>
      <a href="/contact" class="btn btn-primary">Démarrer maintenant →</a>
    </div>
  </section>
  <Footer slot="footer" />
</Layout>
