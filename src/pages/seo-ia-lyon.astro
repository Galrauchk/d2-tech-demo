---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "SEO IA Lyon",
  "provider": { "@type": "Organization", "name": "Nexus AI" },
  "areaServed": { "@type": "City", "name": "Lyon" }
};
---

<Layout
  title="SEO IA Lyon — Référencement Naturel IA Auvergne-Rhône-Alpes | Nexus AI"
  description="Expert SEO IA à Lyon. Dominez Google sur les recherches lyonnaises. Audit SEO gratuit, stratégie IA locale. +180% trafic. Auvergne-Rhône-Alpes."
  schema={schema}
>
  <Header slot="header" />

  <div class="page-hero dot-grid">
    <div class="aurora-bg"><div class="aurora-blob"></div><div class="aurora-blob"></div></div>
    <div class="container page-hero-content">
      <nav class="breadcrumb">
        <a href="/">Accueil</a>
        <span class="breadcrumb-sep">/</span>
        <a href="/villes/lyon">Lyon</a>
        <span class="breadcrumb-sep">/</span>
        <span style="color:var(--cyan);">SEO IA</span>
      </nav>
      <div class="badge badge-violet mb-3">📍 Lyon · SEO IA</div>
      <h1 style="max-width:700px; margin-bottom:1.5rem;">
        SEO IA à Lyon<br/>
        <span class="gradient-text">Visibilité locale & nationale</span>
      </h1>
      <p style="color:var(--text-muted); font-size:1.25rem; max-width:560px; margin-bottom:2.5rem;">
        Prenez la tête des résultats Google sur le marché lyonnais. Notre SEO IA combine expertise locale et technologie de pointe pour des résultats rapides et durables.
      </p>
      <div class="flex gap-2" style="flex-wrap:wrap;">
        <a href="/contact" class="btn btn-primary">Audit SEO Lyon gratuit →</a>
        <a href="/services/seo-ia" class="btn btn-outline">En savoir plus</a>
      </div>
    </div>
  </div>

  <section class="section" style="background:var(--surface-dark);">
    <div class="container">
      <div class="grid-2 fade-in">
        <div>
          <h2 style="margin-bottom:1.5rem;">SEO local <span class="gradient-text">Lyon</span></h2>
          <p style="color:var(--text-muted); margin-bottom:1rem;">Lyon est la 2ème métropole économique de France. Être visible sur Google à Lyon, c'est accéder à un marché de 700 000 habitants et à une économie diversifiée.</p>
          <p style="color:var(--text-muted); margin-bottom:1.5rem;">Notre IA analyse les spécificités du marché lyonnais : mots-clés locaux, comportement des utilisateurs rhônalpins, concurrence sectorielle.</p>
          <a href="/contact" class="btn btn-outline">Demander un audit →</a>
        </div>
        <div class="card tilt-card">
          <h3 style="margin-bottom:1rem; color:var(--cyan);">Résultats SEO Lyon</h3>
          {[
            { metric: '+210%', label: 'Trafic organique moyen' },
            { metric: '4 mois', label: 'Pour voir les premiers résultats' },
            { metric: 'Top 3', label: 'Sur mots-clés cibles Lyon' },
            { metric: '-45%', label: "Coût d'acquisition" }
          ].map(r => (
            <div style="display:flex; justify-content:space-between; padding:0.75rem 0; border-bottom:1px solid var(--border);">
              <span style="color:var(--text-muted);">{r.label}</span>
              <span style="font-weight:700; color:var(--cyan);">{r.metric}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="background:linear-gradient(135deg,rgba(0,229,255,0.05),rgba(124,58,237,0.08)); border-top:1px solid var(--border);">
    <div class="container text-center fade-in">
      <h2 style="margin-bottom:1rem;">Votre audit SEO Lyon<br/><span class="gradient-text">gratuit et sans engagement</span></h2>
      <a href="/contact" class="btn btn-primary">Demander mon audit →</a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
